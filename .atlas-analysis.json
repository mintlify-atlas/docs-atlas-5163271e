  "keyFeatures": [
    "Gradle-based Android project support (AGP 7.2.0+)",
    "Integrated code editor with Java, Kotlin, and XML language servers",
    "Visual UI designer with drag-and-drop interface",
    "Project-aware AI agent for coding assistance",
    "Built-in terminal with essential packages",
    "Git integration for version control",
    "SDK and NDK management",
    "Real-time log reader for app debugging",
    "Asset Studio for drawables and icons",
    "JDK 11 and JDK 17 support",
    "Custom environment variables for builds",
    "Plugin creator for project sub-modules"
  ],
  "publicApiSurface": [
    "IDEApplication - Main application class",
    "EditorActivity - Code editor activity",
    "MainActivity - Project management interface",
    "GradleBuildService - Gradle build execution service",
    "JavaLanguageServer - Java LSP implementation",
    "KotlinLanguageServer - Kotlin LSP implementation",
    "XMLLanguageServer - XML LSP implementation",
    "UIDesigner - Visual layout designer",
    "AIAgentManager - AI assistant manager",
    "TermuxService - Terminal emulator service",
    "ProjectManager - Project lifecycle management",
    "AssetStudio - Drawable and icon generator",
    "GitIntegration - Version control operations",
    "LogReceiverService - Real-time log streaming",
    "TemplateAPI - Project template system"
  ]
